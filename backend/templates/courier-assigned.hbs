<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Delivery Assignment</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f6f9;font-family:'Segoe UI',Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f6f9;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#1a73e8 0%,#0d47a1 100%);padding:40px 48px;text-align:center;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center">
                    <div style="display:inline-block;background:rgba(255,255,255,0.15);border-radius:50%;width:72px;height:72px;line-height:72px;text-align:center;font-size:36px;margin-bottom:16px;">
                      🚚
                    </div>
                  </td>
                </tr>
                <tr>
                  <td align="center">
                    <h1 style="margin:0;color:#ffffff;font-size:26px;font-weight:700;letter-spacing:-0.5px;">
                      Order Flow Logistics
                    </h1>
                    <p style="margin:6px 0 0;color:rgba(255,255,255,0.75);font-size:14px;">
                      Logistics Management Platform
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- New assignment badge -->
          <tr>
            <td align="center" style="padding:36px 48px 0;">
              <div style="display:inline-block;background:#e3f2fd;border:2px solid #1a73e8;border-radius:50px;padding:10px 24px;">
                <span style="color:#0d47a1;font-size:15px;font-weight:600;">📦 &nbsp;New Delivery Assignment</span>
              </div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:32px 48px 40px;">
              <p style="margin:0 0 16px;color:#37474f;font-size:16px;line-height:1.6;">
                Hello, <strong>{{courierName}}</strong>!
              </p>
              <p style="margin:0 0 24px;color:#546e7a;font-size:15px;line-height:1.7;">
                You have been assigned a new delivery order. Please review the details below and start your delivery as soon as possible.
              </p>

              <!-- Order details box -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#f8f9fa;border-radius:10px;padding:24px;margin-bottom:28px;">
                <tr>
                  <td>
                    <p style="margin:0 0 16px;color:#37474f;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">
                      Delivery Details
                    </p>
                    <table cellpadding="0" cellspacing="0" width="100%">
                      <tr>
                        <td style="padding:12px 0;">
                          <span style="color:#546e7a;font-size:13px;font-weight:600;">Order ID:</span>
                          <span style="color:#37474f;font-size:14px;margin-left:12px;font-weight:700;">{{orderId}}</span>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:12px 0;">
                          <span style="color:#546e7a;font-size:13px;font-weight:600;">Supplier:</span>
                          <span style="color:#37474f;font-size:14px;margin-left:12px;">{{organizationName}}</span>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:12px 0;">
                          <span style="color:#546e7a;font-size:13px;font-weight:600;">Delivery Address:</span>
                          <span style="color:#37474f;font-size:14px;margin-left:12px;">{{deliveryAddress}}</span>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:12px 0;">
                          <span style="color:#546e7a;font-size:13px;font-weight:600;">Total Amount:</span>
                          <span style="color:#1a73e8;font-size:14px;margin-left:12px;font-weight:700;">₴{{totalAmount}}</span>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:12px 0;">
                          <span style="color:#546e7a;font-size:13px;font-weight:600;">Items:</span>
                          <span style="color:#37474f;font-size:14px;margin-left:12px;">{{itemCount}} product(s)</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Action items -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#fff3e0;border-radius:10px;border-left:4px solid #f57c00;padding:20px 24px;margin-bottom:28px;">
                <tr>
                  <td>
                    <p style="margin:0 0 12px;color:#e65100;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">
                      ⚡ Next Steps
                    </p>
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding:6px 0;">
                          <span style="color:#e65100;font-size:16px;vertical-align:middle;">1.</span>
                          <span style="color:#795548;font-size:14px;margin-left:10px;vertical-align:middle;">Check order details in your dashboard</span>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:6px 0;">
                          <span style="color:#e65100;font-size:16px;vertical-align:middle;">2.</span>
                          <span style="color:#795548;font-size:14px;margin-left:10px;vertical-align:middle;">Plan your delivery route</span>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:6px 0;">
                          <span style="color:#e65100;font-size:16px;vertical-align:middle;">3.</span>
                          <span style="color:#795548;font-size:14px;margin-left:10px;vertical-align:middle;">Update order status as you progress</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center">
                    <a href="{{dashboardUrl}}"
                       style="display:inline-block;background:linear-gradient(135deg,#1a73e8,#0d47a1);color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;padding:14px 36px;border-radius:8px;letter-spacing:0.3px;">
                      View Delivery in Dashboard
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Divider -->
          <tr>
            <td style="padding:0 48px;">
              <hr style="border:none;border-top:1px solid #eceff1;margin:0;" />
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:28px 48px;text-align:center;">
              <p style="margin:0 0 8px;color:#90a4ae;font-size:13px;">
                This email was sent automatically. Please do not reply to this message.
              </p>
              <p style="margin:0;color:#b0bec5;font-size:12px;">
                © {{year}} Order Flow Logistics. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
